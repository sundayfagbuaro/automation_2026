---
use_default_rules: true

skip_list:
    - "204"  # Lines should be no longer than 160 characters
    - line-length

enable_list:
    - empty-string-compare
    - no-log-password
    - no-same-owner
    - yaml

warn_list:
    - role-name
    - meta-no-info
    - package-reentry
    - template-j2-extension
    - unamed-task
    - yaml